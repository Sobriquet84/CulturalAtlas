    window.scrollTo(0, 0);
  }

  function showTab(country, panel, btn) {
    const view = document.getElementById('view-' + country);
    view.querySelectorAll('.section-panel').forEach(p => p.classList.remove('active'));
    view.querySelectorAll('.section-tab').forEach(t => t.classList.remove('active'));
    document.getElementById(country + '-' + panel).classList.add('active');
    btn.classList.add('active');
  }
</script>

